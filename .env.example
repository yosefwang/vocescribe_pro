# =============================================================================
# Vocescribe — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values.
# In Docker, pass via docker-compose.yml environment section or a .env file.
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string.
# Get from: https://console.neon.tech → project → Dashboard → Connection string
NEON_DB_URL=postgresql://user:password@ep-xxx.region.aws.neon.net/vocescribe?sslmode=require

# ── Authentication (Clerk) ──────────────────────────────────────────────────
# Create app at https://dashboard.clerk.com
# Secret key: server-side only (API routes, webhook verification)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_dXNhYmxlLWtpdHRlbi04My5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_u57SE9hk9MRN37cJVR6XmrpZXFgxOenCsHiSSSDhZI

# ── AI (OpenAI / 兼容接口) ──────────────────────────────────────────────────
# API key。官方 OpenAI 从 https://platform.openai.com/api-keys 获取。
# 使用兼容接口时填写该接口要求的 key（可为任意字符串，视服务而定）。
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# API Base URL（可选）。
# 留空 → 使用官方 OpenAI 接口 (https://api.openai.com/v1)
# 填写后可接入任何 OpenAI 兼容服务，例如：
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   Ollama:        http://localhost:11434/v1
#   LiteLLM proxy: http://localhost:4000
#   OneAPI / 中转:  http://your-proxy.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Chat 补全模型（文本清洗 + 句子切分）。
# 默认: gpt-4o。使用兼容接口时填写该接口部署的模型名。
# 示例: gpt-4o-mini / claude-3-haiku / qwen2.5-72b-instruct
# OPENAI_CHAT_MODEL=gpt-4o

# TTS 语音合成模型。
# 默认: gpt-4o-mini-tts。使用标准 OpenAI TTS 接口可填 tts-1 或 tts-1-hd。
# 注意: tts-1 / tts-1-hd 是标准接口，gpt-4o-mini-tts 是较新接口，按实际支持情况选择。
# OPENAI_TTS_MODEL=gpt-4o-mini-tts

# ── Object Storage (Cloudflare R2) ──────────────────────────────────────────
# Create bucket at https://dash.cloudflare.com → R2
# Account ID: found in Cloudflare dashboard URL or Workers overview
R2_ACCOUNT_ID=your_cloudflare_account_id
# Access key: generate at R2 → Manage R2 API Tokens → Create API Token
#   Permissions needed: Object Read & Write on the target bucket
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Bucket name: the R2 bucket you created (e.g. vocescribe-prod)
R2_BUCKET_NAME=vocescribe-prod

# ── Background Jobs (Inngest) ───────────────────────────────────────────────
# Create app at https://app.inngest.com
# Event key: used to send events from the app to Inngest
INNGEST_EVENT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Signing key: used to verify that Inngest is calling your handler
INNGEST_SIGNING_KEY=signkey-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App URL (for production / Docker) ───────────────────────────────────────
# Used by Clerk for redirect URLs. Omit for localhost dev.
# NEXT_PUBLIC_APP_URL=https://your-domain.com
